<h1 class="mb-4">Employee Details</h1>

<div class="card p-4">
  <p>
    <strong>Name:</strong>
    <%= @employee.full_name %>
  </p>

  <p>
    <strong>Email:</strong>
    <%= @employee.email %>
  </p>

  <p>
    <strong>Country:</strong>
    <%= @employee.country %>
  </p>

  <p>
    <strong>Job Title:</strong>
    <%= @employee.job_title %>
  </p>

  <p>
    <strong>Department:</strong>
    <%= @employee.department %>
  </p>

  <p>
    <strong>Salary:</strong>
    $<%= @employee.salary.to_i %>
  </p>
</div>
